<div class="flex flex-col gap-6 py-3"
     data-controller="generation-polling"
     data-generation-polling-status-url-value="<%= @course_id == 'pending' ? '' : generation_status_path(id: @course_id) %>"
     data-generation-polling-start-url-value="<%= @course_id == 'pending' ? start_generation_path : '' %>">

  <%# Wizard steps header %>
  <div class="flex justify-center py-3">
    <%= wizard_steps_component(
      steps: [
        { icon_name: 'document-text', label: 'Upload doc' },
        { icon_name: 'camera',        label: 'Configure Video' },
        { icon_name: 'numbered-list', label: 'Course Structure' }
      ],
      current_step: 2
    ) %>
  </div>

  <div class="flex flex-col items-center gap-5 py-10">
    <div class="bg-primary-light-50 rounded-[344px] w-[552px] h-[282px] flex items-center justify-center overflow-hidden">
      <lottie-player
        src="<%= asset_path('waiting.json') %>"
        background="transparent"
        speed="1"
        style="width: 251px; height: 251px;"
        loop
        autoplay>
      </lottie-player>
    </div>
    <p class="main-text-md-medium text-letter-color text-center">
      We're creating your course structure !<br>
      It will take sometime.<br>
      Please be patient!
    </p>
    <p class="general-text-md-normal text-letter-color-light text-center"
       data-generation-polling-target="stage">
      Preparing your course…
    </p>
  </div>

</div>
