<div class="flex flex-col gap-6 py-3 max-w-4xl mx-auto w-full">

  <%# Wizard steps header %>
  <div class="flex justify-center py-3">
    <%= wizard_steps_component(
      steps: [
        { icon_name: 'document-text-outline', label: 'Upload doc' },
        { icon_name: 'square-3-stack-3d', label: 'Configure Kit' },
        { icon_name: 'bars-3-bottom-left', label: 'Kit Structure' }
      ],
      current_step: 0
    ) %>
  </div>

  <%= form_with url: classroom_kits_path, method: :post, multipart: true,
                class: 'flex flex-col gap-6',
                data: { controller: 'wizard-upload',
                        action: 'file-selector:change->wizard-upload#onFilesChanged',
                        wizard_upload_existing_count_value: @existing_files.size } do |form| %>

    <%# Card: Document upload %>
    <div class="bg-white border border-line-colour-light rounded-xl p-8 flex flex-col gap-3">
      <p class="main-text-sm-medium text-letter-color">Choose Classroom Kit Documents</p>

      <%= file_selector_component(
        form: form,
        name: 'documents[]',
        type: 'document',
        multiple: true,
        accept: '.pdf,.png,.jpeg,.doc,.docx,.txt',
        support_text: 'File types : pdf, png, jpeg, doc, docx, txt',
        support_text_two: 'File size : 5 mb/file'
      ) %>

      <% if @existing_files.any? %>
        <div class="flex flex-col gap-3">
          <% @existing_files.each do |file| %>
            <div class="file-selector-list-item" data-url="<%= file['url'] %>">
              <%= icon('document-text', css: 'file-selector-list-icon') %>
              <div class="flex-1 min-w-0 overflow-hidden">
                <p class="file-selector-list-item-name"><%= file['name'] %></p>
              </div>
              <button type="button" class="file-selector-list-remove"
                      data-action="click->wizard-upload#removeExisting">
                <%= icon('x-circle', css: 'file-selector-list-remove-icon') %>
              </button>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>

    <%# Footer %>
    <div class="flex justify-between">
      <%= link_to new_creation_path do %>
        <%= button_component(text: 'Back', type: 'outline', colorscheme: 'primary',
                             icon_name: 'arrow-left', icon_position: 'left') %>
      <% end %>
      <%= form.button data: { wizard_upload_target: 'submit' } do %>
        <%= button_component(text: 'Continue', type: 'solid', colorscheme: 'primary',
                             icon_name: 'arrow-right', icon_position: 'right') %>
      <% end %>
    </div>

  <% end %>

</div>
