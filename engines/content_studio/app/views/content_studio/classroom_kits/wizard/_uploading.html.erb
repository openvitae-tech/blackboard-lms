<div class="flex flex-col items-center gap-6 py-16" data-generation-polling-target="uploadPhase">
  <%= image_tag 'upload.gif', class: 'w-40 h-40', alt: 'Uploading' %>
  <div class="flex flex-col items-center gap-2 text-center">
    <p class="heading-2xl text-letter-color">Uploading your document</p>
    <p class="main-text-md-medium text-letter-color-light"
       data-generation-polling-target="stage">
      Hold tight! Your file is on its way. This usually takes a few seconds.
    </p>
  </div>
</div>
