<div class="flex flex-col gap-7">
  <div class="bg-white border border-line-colour-light rounded-2xl p-12 flex flex-col items-center gap-6">
    <%= icon('puzzle-piece', css: 'w-12 h-12 text-primary', span_css: 'bg-primary-light-50 rounded-2xl w-20 h-20') %>
    <div class="flex flex-col gap-2 items-center text-center">
      <p class="heading-2xl text-primary">Classroom Kit</p>
      <p class="general-text-lg-normal text-letter-color-light">
        AI-generated slides, trainer guide, handouts, and quiz — ready for your classroom.
      </p>
    </div>
    <%= link_to kit_structure_path(id: :demo) do %>
      <%= button_component(text: 'Generate Kit', colorscheme: 'primary', size: 'md',
                           icon_name: 'chevron-right', icon_position: 'right') %>
    <% end %>
  </div>
</div>
