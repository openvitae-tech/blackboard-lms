<div class="flex flex-col items-center gap-5 py-16" data-generation-polling-target="uploadPhase">
  <%= image_tag 'upload.gif', class: 'w-[150px] h-[150px] object-contain', alt: 'Uploading' %>
  <div class="flex flex-col items-center gap-3 text-center">
    <p class="heading-2xl text-letter-color">Uploading your document/Prompt</p>
    <p class="main-text-md-medium text-letter-color"
       data-generation-polling-target="stage">
      Hold tight ! Your file is on its way. This usually takes a few seconds.
    </p>
  </div>
</div>
