<% color_class = { primary: 'bg-primary', secondary: 'bg-secondary', danger: 'bg-danger' }.fetch(color, 'bg-primary') %>
<% if full_width %>
  <div class="h-1.5 w-full bg-primary-light-100 rounded-full">
    <div class="h-1.5 <%= color_class %> rounded-full" style="width: <%= fill %>%"></div>
  </div>
<% else %>
  <div class="flex w-[52px] md:w-[120px] h-[6px] md:h-2 border-none">
    <div class="h-1 grow bg-primary-light-100 w-full h-full border border-primary-light-100 rounded md:rounded-lg">
      <div class="h-1 <%= color_class %> h-full border rounded-sm md:rounded" style="width: <%= fill %>%"></div>
    </div>
  </div>
<% end %>
