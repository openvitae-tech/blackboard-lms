<div id="course-select-component" data-controller="course-select">
  <%= _course_select_search_component(search_context:, tags:) %>

  <div class="mb-4" id="course-select-list">
    <%= _course_select_list_component(search_context:, courses:) %>
  </div>

  <%= _course_select_deadline_modal_component(courses:, submit_path:, search_context:) %>

  <div id="footer" class="sticky bottom-0 -mb-8 flex gap-3 justify-center items-center bg-white px-6 md:px-16 py-5 -mx-5 md:-mx-16 z-10 border-t border-line-colour-light">
    <%= link_to cancel_link do %>
      <%= button_component(text: t("button.cancel"), type: "outline", size: "sm") %>
    <% end %>
    <button type="button"
            class="flex-none"
            disabled
            data-course-select-target="assignButton"
            data-action="click->course-select#openModal">
      <%= button_component(text: t("button.assign_course"), size: "sm", disabled: true,
            html_options: { data: { course_select_target: "assignButtonInner" } }) %>
    </button>
  </div>
</div>
