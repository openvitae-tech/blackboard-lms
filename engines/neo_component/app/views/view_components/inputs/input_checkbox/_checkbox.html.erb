<% element = content_tag :div, class: "relative flex justify-center items-center" do %>
  <% if input.form.present? %>
    <%= input.form.check_box input.name,
          input.html_options,
          input.value,
          nil %>
  <% else %>
    <%= check_box_tag input.name,
          input.value,
          input.html_options[:checked],
          input.html_options.except(:checked) %>
  <% end %>
  <div class="w-5 h-5 rounded-sm border <%= input.box_style %>"></div>
  <span class="absolute hidden peer-checked:flex w-5 h-5 items-center justify-center pointer-events-none <%= input.check_color %>">
    <%= icon("check", css: "w-5 h-5", stroke_width: "2.0") %>
  </span>
<% end %>

<% label_tag = content_tag :div, input.label, class: "main-text-md-normal" %>

<%= arrange_tags(label_tag, element, input.label_position) %>
