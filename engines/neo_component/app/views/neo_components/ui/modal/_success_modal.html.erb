<%= modal_box_component(variant: :success) do %>
  <%= form_with url: "#", method: :post do |form| %>
    <div class="relative w-full bg-white flex items-center justify-between">

        <div class="flex flex-col gap-6 w-[162px] md:w-[279px]">
            <p class="main-text-lg-semibold">
            Learning Partner Created !
            </p>

            <div class="flex flex-col md:flex-row gap-2">
            <%= button_component(type: 'outline', text: "Dismiss", size:"sm", html_options: { data: { action: "click->modals#closeModal" } }) %>

            <%= form.button type: :submit do %>
                <%= button_component(text: "Create payment plan", size: "sm") %>
            <% end %>
            </div>
        </div>

    </div>

  <% end %>
<% end %>
