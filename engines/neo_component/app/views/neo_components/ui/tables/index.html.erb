<div class="my-6">
  <%= render "shared/components/back_button", back_link: ui_components_path %>
</div>

<div class="heading heading-medium">Sample Table</div>

<div class="mt-5">
  <div class="flex flex-col py-4 md:px-6 md:shadow-[0px_0px_4px_0px_#33333329] rounded">

    <%= render "shared/components/table_heading",
      columns: [
        { name: "ID", span: "col-span-2", alignment: "justify-start" },
        { name: "Name", span: "col-span-5", alignment: "justify-start" },
        { name: "Type", span: "col-span-3", alignment: "justify-center" },
        { name: "Actions", span: "col-span-2", alignment: "justify-end" }
      ]
    %>

    <div class="bg-white md:divide-y md:divide-slate-grey-light">
      <% @sample_rows.each do |row| %>
        <%= render "shared/components/table_rows",
          data: [
            { span: "col-span-2", alignment: "justify-start", method: ->(_row) { { partial: nil, locals: { value: _row.id } } } },
            { span: "col-span-5", alignment: "justify-start", method: ->(_row) { table_cell_name(_row, avatar: false) } },
            { span: "col-span-3", alignment: "justify-center", method: ->(_row) { { partial: nil, locals: { value: _row.type } } } },
            { span: "col-span-2", alignment: "justify-end", method: ->(_row) {
                table_actions(_row, [
                  { label: "Edit", icon: "pencil", type: "secondary", size: "sm" },
                  { label: "Delete", type: "danger", size: "sm" }
                ])
              }
            }
          ],
          row: row,
          table_type: "sample",
          extra_data: {}
        %>
      <% end %>
    </div>

  </div>
</div>
