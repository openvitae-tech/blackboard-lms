<%= button_to generate_certificate_profile_path(enrollment_id: enrollment.id),
             method: :post,
             class: "text-left" do %>
  <div class="flex flex-col justify-center rounded-xl overflow-hidden border border-line-colour w-[280px] h-[135px] bg-white-light">
    <div class="flex items-center justify-center rounded-t-xl">
      <%= icon("document-text", css: "h-6 w-6 text-primary-light") %>
    </div>
    <div class="px-3 py-2.5 flex flex-col gap-1 items-center">
      <p class="general-text-lg-normal line-clamp-1 text-letter-color-light"><%= enrollment.course.title %></p>
      <span class="main-text-sm-normal text-primary"><%= t("my_profile.my_certificates.request_certificate") %></span>
    </div>
  </div>
<% end %>
