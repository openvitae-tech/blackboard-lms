<%= turbo_stream.update "flash", partial: "shared/components/flash" %>
<%= turbo_stream.replace "modal" do %>
  <%= turbo_frame_tag "modal" %>
<% end %>
<%= turbo_stream.update "programs-list" do %>
  <%= render 'programs_list', programs: @learning_partner.programs.filter_by_name(params[:term]).page(params[:page]).per(Program::DEFAULT_PER_PAGE_SIZE) %>
<% end %>
<%= turbo_stream.replace "program-show-content", partial: "programs/show_content", locals: { program: @program } %>
