<%= turbo_stream.update "flash", partial: "shared/components/flash" %>
<%= turbo_stream.replace "modal" do %>
  <%= turbo_frame_tag "modal" %>
<% end %>
<%= turbo_stream.update "programs-list" do %>
  <%= render 'programs_list', programs: @programs %>
<% end %>
<%= turbo_stream.replace "program-show-content", partial: "programs/show_content", locals: { program: @program, learner_mode: @learner_mode, courses: @courses } %>
