<% modal_footer = capture do %>
  <div class="flex gap-2 sticky bottom-0 bg-white w-full">
    <div class="flex-1" data-action="click->modals#closeModal">
      <%= button_component(text: "Cancel", type: "outline") %>
    </div>
    <%= button_tag form: "change-email-form", class: "flex-1" do %>
      <%= button_component(text: "Send Verification") %>
    <% end %>
  </div>
<% end %>

<%= modal_box_component(title: "Change Email", modal_footer:) do %>
  <%= form_with(model: @user, url: update_email_user_settings_path, method: :post, id: "change-email-form", class: "flex flex-col gap-6") do |form| %>
    <div class="flex flex-col gap-4">
      <%= input_text_component(form:, name: :email, label: "Email", type: "email",
            placeholder: "Enter your email address", subtext: 'Example: deepak@example.com') %>
    </div>
  <% end %>
<% end %>
