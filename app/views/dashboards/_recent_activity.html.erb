<div class="bg-white rounded-xl border border-line-colour-light p-5">
  <h2 class="main-text-lg-semibold mb-4">Recent Activity</h2>
  <div class="flex flex-col divide-y divide-line-colour-light">
    <% @dashboard.recent_activities.each do |activity| %>
      <div class="flex items-start justify-between py-3">
        <div class="flex items-start gap-3">
          <div class="w-3 h-3 rounded-full mt-1 flex-none flex items-center justify-center
            <%= activity[:type] == 'completed' ? 'bg-secondary-light' :
                activity[:type] == 'certificate' ? 'bg-gold-light' : 'bg-primary-light-50' %>">
            <div class="w-1.5 h-1.5 rounded-full
              <%= activity[:type] == 'completed' ? 'bg-secondary' :
                  activity[:type] == 'certificate' ? 'bg-gold' : 'bg-primary' %>">
            </div>
          </div>
          <div>
            <p class="general-text-sm-normal">
              <span class="main-text-sm-medium"><%= activity[:user]&.display_name %></span>
              <%= activity[:action_text] %>
            </p>
            <p class="general-text-sm-normal text-letter-color-light"><%= activity[:resource_name] %></p>
            <p class="general-text-xs-normal text-letter-color-light mt-0.5"><%= time_ago_in_words(activity[:created_at]) %> ago</p>
          </div>
        </div>
        <% if activity[:type] == 'certificate' %>
          <%= link_to "#", class: "flex items-center gap-1 text-primary general-text-sm-normal flex-none" do %>
            <%= icon("chat-bubble-bottom-center-text", css: "h-4 w-4") %>
            <span class="main-text-sm-normal">Congrats</span>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex gap-3 mt-4">
    <div class="flex-1 bg-secondary-light rounded-lg p-3 text-center">
      <p class="main-text-lg-semibold text-secondary"><%= @dashboard.completions_count %></p>
      <p class="general-text-sm-normal text-letter-color-light">Completions</p>
    </div>
    <div class="flex-1 bg-gold-light rounded-lg p-3 text-center">
      <p class="main-text-lg-semibold text-gold"><%= @dashboard.certificates_count %></p>
      <p class="general-text-sm-normal text-letter-color-light">Certificates</p>
    </div>
    <div class="flex-1 bg-primary-light-100 rounded-lg p-3 text-center">
      <p class="main-text-lg-semibold text-primary"><%= @dashboard.new_starts_count %></p>
      <p class="general-text-sm-normal text-letter-color-light">New Starts</p>
    </div>
  </div>

  <%= link_to recent_activity_dashboards_path(duration: params[:duration]), class: "flex items-center justify-center gap-1 mt-4 main-text-sm-normal text-primary" do %>
    <span>View all activity</span>
    <%= icon("arrow-right", css: "h-4 w-4") %>
  <% end %>
</div>
