<div class="bg-white rounded-xl border border-line-colour-light">

  <% header_content = capture do %>
    <div class="flex flex-col md:flex-row gap-1 md:gap-3">
      <h2 class="main-text-lg-semibold"><%= t("dashboard.started_vs_completed.title") %></h2>
      <div class="hidden md:flex items-center gap-3 mt-1 ">
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded-full bg-secondary"></div>
          <span class="general-text-sm-normal"><%= t("dashboard.started_vs_completed.completed") %></span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded-full bg-primary"></div>
          <span class="general-text-sm-normal"><%= t("dashboard.started_vs_completed.started") %></span>
        </div>
      </div>
    </div>
    <%= link_to started_vs_completed_dashboards_path(duration: params[:duration]), class: "hidden md:flex main-text-sm-normal text-primary items-center gap-1 mb-4" do %>
      <span><%= t("dashboard.actions.view_all") %></span>
      <%= icon("arrow-right", css: "h-4 w-4") %>
    <% end %>
  <% end %>

  <%= accordion_component(
        header: header_content,
        wrapper_class: "",
        icon_class: "md:hidden",
        content_class: "md:!block"
      ) do %>
    <div class="px-5 pb-5">

      <div class="md:hidden flex items-center gap-3 mt-1 pb-5">
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded-full bg-secondary"></div>
          <span class="general-text-sm-normal"><%= t("dashboard.started_vs_completed.completed") %></span>
        </div>
        <div class="flex items-center gap-1">
          <div class="w-3 h-3 rounded-full bg-primary"></div>
          <span class="general-text-sm-normal"><%= t("dashboard.started_vs_completed.started") %></span>
        </div>
      </div>
      <div class="flex flex-col gap-3">
        <% @dashboard.started_vs_completed.each do |item| %>
          <div class="mb-3">
            <div class="flex justify-between gap-2">
              <p class="main-text-sm-medium line-clamp-1 mb-1"><%= item[:course].title %></p>
              <span class="general-text-sm-normal w-8 text-right"><%= item[:completed] + item[:started] %>/<%= item[:total] %></span>
            </div>
            <%= progressbar_component(segments: [
              { value: item[:completed_percent], color: :secondary },
              { value: item[:started_percent], color: :primary }
            ]) %>
          </div>
        <% end %>
      </div>
      <%= link_to started_vs_completed_dashboards_path(duration: params[:duration]), class: "md:hidden flex main-text-sm-normal text-primary justify-center gap-1 mb-4" do %>
        <span><%= t("dashboard.actions.view_all") %></span>
        <%= icon("arrow-right", css: "h-4 w-4") %>
      <% end %>

      <% worst = @dashboard.started_vs_completed.max_by { |item| item[:total] - item[:completed] }
        gap = worst ? (worst[:total] - worst[:completed]) : 0 %>
      <% if gap > 0 %>
        <div class="mt-4 bg-gold-light rounded-lg p-3 flex items-center justify-between gap-3">
          <div class="flex items-start gap-2 min-w-0">
            <%= icon("exclamation-circle-solid", css: "h-4 w-4 text-gold flex-none mt-0.5") %>
            <p class="general-text-sm-normal text-letter-color-medium">
              <span class="main-text-sm-medium"><%= worst[:course].title.truncate(30) %></span>
              <%= t("dashboard.started_vs_completed.widest_gap") %>
              <% if worst[:started] == 0 %>
                <%= t("dashboard.started_vs_completed.none_started", total: worst[:total]) %>
              <% else %>
                <%= t("dashboard.started_vs_completed.gap_detail", started: worst[:started], completed: worst[:completed], total: worst[:total]) %>
              <% end %>
            </p>
          </div>
          <%= link_to nudge_all_dashboards_path(course_id: worst[:course].id, team_id: params[:team_id]), data: { turbo_frame: 'modal' }, class: "flex items-center gap-1 text-primary flex-none" do %>
            <%= icon("chat-bubble-bottom-center-text", css: "h-4 w-4") %>
            <span class="main-text-sm-normal"><%= t("dashboard.actions.nudge") %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
