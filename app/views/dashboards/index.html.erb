<div data-controller="custom-date">
<div class="flex items-center justify-between mb-4 px-1">
  <div class="flex items-center gap-3">
    <% if @team.parent_team %>
      <%= render 'shared/components/back_button',
            back_link: dashboard_path(team_id: @team.parent_team.id, duration: params[:duration]) %>
    <% end %>
    <div>
      <div class="heading heading-medium flex gap-1">
        <span class=""><%= t("dashboard.index.team_label") %> </span><span class=""><%= @team.name %></span>
      </div>
      <p class="general-text-sm-normal text-letter-color-light"><%= t("dashboard.index.subtitle", count: @team.users.active.count) %></p>
    </div>
  </div>
  <div class="flex w-fit items-center gap-2">
    <%= dropdown_component(
      name: "duration",
      options: duration_select_options(@team),
      value: duration_select_value(@team),
      html_options: duration_select_html_options
    ) %>
    <%= link_to export_dashboards_path(team_id: @team.id, duration: params[:duration], from_date: params[:from_date], to_date: params[:to_date]),
             data: { controller: "download", action: "click->download#start" } do %>
      <%= button_component(text: "Export", icon_name: "arrow-down-tray", type: "outline", icon_position: "left") %>
    <% end %>
  </div>
</div>
<div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
  <%= render 'stat_card',
      title: t("dashboard.stats.active_learners"),
      icon_name: 'user-group',
      value: @dashboard.active_learners_count,
      delta: @dashboard.active_learners_delta,
      delta_label: t("dashboard.index.active_learners_delta", count: @dashboard.active_learners_delta),
      delta_suffix: period_label(@dashboard.duration) %>

  <%= render 'stat_card',
      title: t("dashboard.stats.avg_completion"),
      icon_name: 'check-badge',
      value: "#{@dashboard.completion_percent_metric}%",
      delta: @dashboard.completion_percent_delta,
      delta_label: "#{@dashboard.completion_percent_delta}%",
      delta_suffix: period_label(@dashboard.duration) %>

  <%= render 'stat_card',
      title: t("dashboard.stats.avg_watch_time"),
      icon_name: 'clock',
      value: duration_in_words(@dashboard.average_time_spent_metric),
      delta: @dashboard.average_time_spent_delta,
      delta_label: "#{duration_in_words(@dashboard.average_time_spent_delta.abs)}",
      delta_suffix: period_label(@dashboard.duration) %>

  <%= render 'stat_card',
      title: t("dashboard.stats.certificates_earned"),
      icon_name: 'document-text-outline',
      value: @dashboard.certificates_count,
      delta: @dashboard.certificates_delta,
      delta_label: "#{@dashboard.certificates_delta}",
      delta_suffix: period_label(@dashboard.duration) %>
</div>

<%= render 'dashboards/falling_behind' %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <%# Left column — Total Engagement, Deadlines, Recent Activity %>
  <div class="flex flex-col gap-4">
    <%= render 'dashboards/total_engagement' %>
    <%= render 'dashboards/deadlines' %>
    <%= render 'dashboards/recent_activity' %>
  </div>

  <%# Right column — Learning Activity, Self-Assigned, Started vs Completed, Team Progress %>
  <div class="flex flex-col gap-4">
    <%= render 'dashboards/learning_activity' %>
    <%= render 'dashboards/self_assigned' %>
    <%= render 'dashboards/started_vs_completed' %>
    <%= render 'dashboards/team_progress' %>
  </div>
</div>
<%= render 'dashboards/custom_date_modal', action_url: dashboards_path %>
</div>
