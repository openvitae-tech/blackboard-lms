<% safe_origin = safe_origin_path(params[:origin]) %>
<div class="relative" data-controller="custom-date">
  <div class="relative -mx-5 md:-mx-16 px-5 md:px-16 py-5 bg-primary-light-100 -mt-5 h-[148px] flex items-start justify-between">
    <div class="flex items-center gap-3">
      <%= render 'shared/components/back_button', back_link: safe_origin || dashboards_path %>
      <div>
        <h2 class="main-text-lg-semibold"><%= @member.display_name %></h2>
        <p class="general-text-sm-normal text-letter-color-light">
          <%= @member.team&.name %>
          <% if @member.last_sign_in_at %>
            &nbsp;|&nbsp;<%= t("dashboard.member_profile.last_active", time: time_ago_in_words(@member.last_sign_in_at)) %>
          <% end %>
        </p>
      </div>
    </div>
    <div class="z-20">
      <%= dropdown_component(
        name: "duration",
        options: duration_select_options(@team, member: @member, origin: safe_origin),
        value: duration_select_value(@team, member: @member, origin: safe_origin),
        html_options: duration_select_html_options
      ) %>
    </div>
  </div>

  <div class="absolute top-20 w-full">
    <%# Stats cards %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <% self_assigned = @member_data[:self_assigned_count].to_i %>
      <%= render 'stat_card',
          title: t("dashboard.stats.courses"),
          icon_name: 'book-open',
          value: @member_data[:courses_count],
          delta: self_assigned,
          delta_label: t("dashboard.member_profile.self_assigned_delta", count: self_assigned.abs),
          delta_suffix: period_label(@dashboard.duration) %>

      <%= render 'stat_card',
          title: t("dashboard.stats.avg_completion"),
          icon_name: 'check-badge',
          value: "#{@member_data[:avg_completion_percent]}%",
          delta: @member_data[:avg_completion_delta].to_i,
          delta_label: "#{@member_data[:avg_completion_delta].to_i.abs}%",
          delta_suffix: period_label(@dashboard.duration) %>

      <%= render 'stat_card',
          title: t("dashboard.stats.avg_watch_time"),
          icon_name: 'clock',
          value: duration_in_words(@member_data[:total_watch_seconds].to_i),
          delta: @member_data[:watch_time_delta].to_i,
          delta_label: duration_in_words(@member_data[:watch_time_delta].to_i.abs),
          delta_suffix: period_label(@dashboard.duration) %>

      <%= render 'stat_card',
          title: t("dashboard.stats.certificates_earned"),
          icon_name: 'document-text-outline',
          value: @member_data[:certificates_count].to_i,
          delta: @member_data[:certificates_delta].to_i,
          delta_label: "#{@member_data[:certificates_delta].to_i.abs}",
          delta_suffix: period_label(@dashboard.duration) %>
    </div>

    <%# Alert banner %>
    <% if @member_data[:avg_completion_percent] >= 80 && @member_data[:courses_count] > 0 %>
      <div class="mb-6 bg-secondary-light rounded-lg p-4 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 border border-line-colour-light rounded-lg bg-white">
            <%= icon("star-solid", css: "h-5 w-5 text-secondary-dark flex-none") %>
          </div>
          <p class="general-text-sm-normal"><span class="main-text-sm-medium"><%= @member.display_name %></span> <%= t("dashboard.member_profile.crushing_it") %></p>
        </div>
        <%= link_to appreciate_member_dashboards_path(user_id: @member.id, banner_type: 'crushing_it'),
            data: { turbo_frame: 'modal' },
            class: "flex items-center gap-1 text-primary flex-none" do %>
          <%= icon("chat-bubble-bottom-center-text", css: "h-4 w-4") %>
          <span class="main-text-sm-normal"><%= t("dashboard.actions.appreciate") %></span>
        <% end %>
      </div>
    <% elsif @member_data[:avg_completion_percent] < 20 && @member_data[:courses_count] > 0 %>
      <div class="mb-6 bg-danger-light rounded-lg p-4 flex items-center justify-between gap-3">
        <div class="flex items-center gap-2">
          <%= icon("exclamation-circle-solid", css: "h-5 w-5 text-danger flex-none") %>
          <p class="general-text-sm-normal"><span class="main-text-sm-medium"><%= @member.display_name %></span> <%= t("dashboard.member_profile.falling_behind") %></p>
        </div>
        <%= link_to appreciate_member_dashboards_path(user_id: @member.id, banner_type: 'falling_behind'),
            data: { turbo_frame: 'modal' },
            class: "flex items-center gap-1 text-primary flex-none" do %>
          <%= icon("chat-bubble-bottom-center-text", css: "h-4 w-4") %>
          <span class="main-text-sm-normal"><%= t("dashboard.actions.nudge") %></span>
        <% end %>
      </div>
    <% end %>

    <%# Two-column layout %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <%# Left column %>
      <div class="flex flex-col gap-4">
        <%# Engagement %>
        <div class="bg-white rounded-xl border border-line-colour-light">
          <% eng_header = capture do %>
            <div class="flex items-center justify-between w-full">
              <p class="main-text-lg-semibold"><%= t("dashboard.engagement.title") %></p>
              <p class="general-text-sm-normal text-letter-color-light hidden md:block"><%= t("dashboard.engagement.hrs_watched_per_day") %></p>
            </div>
          <% end %>
          <%= accordion_component(
                header: eng_header,
                wrapper_class: "",
                icon_class: "md:hidden",
                content_class: "md:!block"
              ) do %>
            <div class="px-5 pb-5">
              <p class="general-text-sm-normal text-letter-color-light md:hidden mb-4"><%= t("dashboard.engagement.hrs_watched_per_day") %></p>
              <%= column_chart [
                { name: t("dashboard.engagement.hours_watched"), data: @member_data[:engagement_series] }
              ], height: "150px",
              dataset: { backgroundColor: '#D9E3F5', borderWidth: 0 },
              library: {
                plugins: { legend: { display: false } },
                scales: { y: { min: 0, ticks: { stepSize: 1 } } }
              } %>
              <div class="flex gap-8 mt-4 pt-4 border-t border-line-colour-light">
                <div>
                  <p class="main-text-lg-medium text-primary"><%= @member_data[:total_watch_hours] %> hrs</p>
                  <p class="general-text-sm-normal text-letter-color-light"><%= t("dashboard.engagement.hrs_per_period", period: period_label(@dashboard.duration)) %></p>
                </div>
                <div>
                  <p class="main-text-lg-medium text-primary"><%= @member_data[:daily_avg_watch_hours] %> hrs</p>
                  <p class="general-text-sm-normal text-letter-color-light"><%= t("dashboard.engagement.daily_avg") %></p>
                </div>
                <div>
                  <p class="main-text-lg-medium text-primary"><%= @member_data[:member_peak_day] || '—' %></p>
                  <p class="general-text-sm-normal text-letter-color-light"><%= t("dashboard.engagement.peak_day") %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <%# Self-Assigned — open by default %>
        <div class="bg-white rounded-xl border border-line-colour-light">
          <% sa_header = capture do %>
            <h2 class="main-text-lg-semibold"><%= t("dashboard.self_assigned.title") %></h2>
          <% end %>
          <%= accordion_component(
                header: sa_header,
                wrapper_class: "",
                icon_class: "md:hidden",
                content_class: "md:!block"
              ) do %>
            <div class="px-5 pb-5">
              <p class="general-text-sm-normal text-letter-color-light mb-4"><%= t("dashboard.self_assigned.subtitle") %></p>
              <div class="flex flex-col gap-3">
                <% if @member_data[:self_assigned_enrollments].any? %>
                  <% @member_data[:self_assigned_enrollments].each do |enrollment| %>
                    <div class="flex items-center justify-between">
                      <p class="main-text-sm-medium line-clamp-1"><%= enrollment.course.title %></p>
                      <div class="relative w-10 h-10 flex-none">
                        <svg viewBox="0 0 36 36" class="w-10 h-10 -rotate-90">
                          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#D9E3F5" stroke-width="3"/>
                          <circle cx="18" cy="18" r="15.9" fill="none" stroke="#0041B9" stroke-width="3"
                            stroke-dasharray="<%= enrollment.progress %>, 100"/>
                        </svg>
                        <span class="absolute inset-0 flex items-center justify-center general-text-xs-normal"><%= enrollment.progress %>%</span>
                      </div>
                    </div>
                  <% end %>
                <% else %>
                  <p class="general-text-sm-normal text-letter-color-light"><%= t("dashboard.self_assigned.empty") %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <%# Learning Activity %>
        <div class="bg-white rounded-xl border border-line-colour-light">
          <% la_header = capture do %>
            <h2 class="main-text-lg-semibold"><%= t("dashboard.learning_activity.title") %></h2>
          <% end %>
          <%= accordion_component(
                header: la_header,
                wrapper_class: "",
                icon_class: "md:hidden",
                content_class: "md:!block"
              ) do %>
            <div class="px-5 pb-5">
              <div class="flex items-center gap-2">
                <div class="bg-secondary-light h-10 w-10 p-4 rounded-lg flex items-center justify-center flex-none">
                  <%= icon("puzzle-piece", css: "h-6 w-6 text-primary") %>
                </div>
                <div class="flex flex-col w-full gap-1">
                  <div class="flex justify-between w-full">
                    <span class="general-text-md-medium"><%= t("dashboard.learning_activity.quizzes_passed") %></span>
                    <span class="general-text-sm-normal"><%= @member_data[:quizzes_passed] %>/<%= @member_data[:total_quizzes] %></span>
                  </div>
                  <% quiz_color = @member_data[:quiz_pass_rate] == 100 ? :secondary : @member_data[:quiz_pass_rate] < 20 ? :danger : :primary %>
                  <%= progressbar_component(value: @member_data[:quiz_pass_rate], color: quiz_color) %>
                  <p class="general-text-sm-normal text-letter-color-light mt-1"><%= t("dashboard.learning_activity.pass_rate", rate: @member_data[:quiz_pass_rate]) %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <%# Right column %>
      <div class="flex flex-col gap-4">
        <%# Course Progress %>
        <div class="bg-white rounded-xl border border-line-colour-light">
          <% cp_header = capture do %>
            <h2 class="main-text-lg-semibold"><%= t("dashboard.course_progress.title") %></h2>
          <% end %>
          <%= accordion_component(
                header: cp_header,
                wrapper_class: "",
                icon_class: "md:hidden",
                content_class: "md:!block"
              ) do %>
            <div class="px-5 pb-5">
              <div class="flex flex-col divide-y divide-line-colour-light">
                <% @member_data[:course_enrollments].each do |enrollment| %>
                  <div class="py-3">
                    <div class="flex justify-between mb-1">
                      <p class="main-text-sm-medium line-clamp-1"><%= enrollment.course.title %></p>
                      <span class="general-text-sm-normal text-letter-color-light w-12 text-right"><%= enrollment.progress %>%</span>
                    </div>
                    <% course_color = enrollment.progress == 100 ? :secondary : enrollment.progress < 20 ? :danger : :primary %>
                    <%= progressbar_component(value: enrollment.progress, color: course_color) %>
                  </div>
                <% end %>
                <% if @member_data[:course_enrollments].empty? %>
                  <p class="general-text-sm-normal text-letter-color-light py-4"><%= t("dashboard.course_progress.empty") %></p>
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
    <%= render 'dashboards/custom_date_modal', action_url: team_member_profile_dashboards_path, user_id: @member.id, origin: safe_origin %>
  </div>
</div>
